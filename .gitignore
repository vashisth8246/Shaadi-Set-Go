# Project-wide .gitignore for Shaadi Set Go

# Environment variables and secrets
.env
.env.local
.env.*.local
.env.production
.env.production.local

# IDE and editor
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# OS-specific
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride

# Build outputs
dist
build
dist-ssr
*.local
.next
out

# Dependencies
node_modules
npm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
pnpm-error.log*
lerna-debug.log
package-lock.json

# Logs
logs
*.log

# Temporary files
tmp/
temp/
.tmp

# Database
*.db
*.sqlite
*.sqlite3
mongodb_dump.json

# Uploads (usually handled by server)
backend/uploads/*
!backend/uploads/.gitkeep

# Testing
.nyc_output
coverage
.mocha

# Production files (generated, don't commit)
.vercel
out/

# Cache
.cache
.parcel-cache

# Misc
.eslintcache
