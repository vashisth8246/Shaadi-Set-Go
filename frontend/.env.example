# Frontend Environment Variables for Shaadi Set Go

# API Configuration
# Set this to your backend API URL in production
# Examples:
#   Local development: http://localhost:5000
#   Production: https://api.shaadisetweddings.com
# If not set, the app will use relative paths (requests to same domain)
VITE_API_BASE_URL=http://localhost:5000

# Build optimization (optional)
# Enable source maps for debugging (set to true in development, false in production)
# VITE_SOURCEMAP=false

# Analytics (optional)
# VITE_ANALYTICS_ID=

# Feature flags (optional)
# VITE_ENABLE_BETA_FEATURES=false
