# Backend Environment Variables Example
# Copy this file to .env and fill in with actual values

# Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/wedding_vendors_SSG_loc
# For MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://username:password@cluster-name.mongodb.net/database-name?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development
# Set to 'production' for production deployments

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Use a strong random string in production: openssl rand -base64 32

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
# For production: https://your-frontend-url.vercel.app

# Email Configuration (optional, for password resets and notifications)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
# Use app-specific password for Gmail, not your regular password
# Generate at: https://myaccount.google.com/apppasswords

# File Upload Configuration (optional)
MAX_FILE_SIZE=5242880
# Size in bytes (default 5MB)
UPLOAD_DIR=./uploads

# Session Configuration
SESSION_SECRET=your-session-secret-key
SESSION_TIMEOUT=86400000
# Timeout in milliseconds (default 24 hours)

# Rate Limiting (optional)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
# 100 requests per 15 minutes

# Database Connection Options (optional)
DB_TIMEOUT=30000
# Connection timeout in milliseconds

# Logging (optional)
LOG_LEVEL=info
# Options: error, warn, info, debug
